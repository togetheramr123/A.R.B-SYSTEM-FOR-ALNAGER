'use client';

import { useState } from 'react';
import { Plus, Trash2, GripVertical, ArrowRight, SlidersHorizontal } from 'lucide-react';
import { UseFormRegister, Control } from 'react-hook-form';

export interface Column<T = any> {
    id: string;
    label: string;
    width?: string;
    minWidth?: string;
    required?: boolean;
    defaultVisible?: boolean;
    renderHeader?: () => React.ReactNode;
    renderCell: (field: T, index: number, register: UseFormRegister<any>, control?: Control<any>) => React.ReactNode;
}

interface EditableDynamicTableProps<T = any> {
    columns: Column<T>[];
    fields: T[]; // fields should have a `type` property: 'product' | 'section' | 'note'
    register: UseFormRegister<any>;
    control?: Control<any>; // Optional control for Controller components
    onRemove: (index: number) => void;
    onAdd?: () => void;
    onAddSection?: () => void;
    onAddNote?: () => void;
    disableAdd?: boolean;
    readOnly?: boolean;
    fieldArrayName?: string; // New prop
}

export function EditableDynamicTable({
    columns,
    fields,
    register,
    control,
    onRemove,
    onAdd,
    onAddSection,
    onAddNote,
    disableAdd,
    readOnly = false,
    fieldArrayName = 'lines' // Default to 'lines'
}: EditableDynamicTableProps) {
    // ...
    // ...

    // Initialize visibility state based on props
    const [visibleColumns, setVisibleColumns] = useState<Record<string, boolean>>(() => {
        const initial: Record<string, boolean> = {};
        columns.forEach(col => {
            initial[col.id] = col.required || col.defaultVisible !== false;
        });
        return initial;
    });

    const [showSettings, setShowSettings] = useState(false);
    const [activeRow, setActiveRow] = useState<number | null>(null);

    const toggleColumn = (id: string) => {
        setVisibleColumns(prev => ({
            ...prev,
            [id]: !prev[id]
        }));
    };

    const activeColumns = columns.filter(col => visibleColumns[col.id]);

    const handleKeyDown = (e: React.KeyboardEvent<HTMLTableSectionElement>) => {
        if (e.key === 'Tab' && !e.shiftKey && onAdd && !readOnly && !disableAdd) {
            const target = e.target as HTMLElement;
            // Get all focusable inputs within the body
            const focusableElements = Array.from(e.currentTarget.querySelectorAll('input:not([type="hidden"]), select, textarea, button'))
                .filter(el => !(el as HTMLInputElement).disabled && (el as HTMLElement).tabIndex !== -1) as HTMLElement[];
            
            // If the element we tabbed out of is the last one in the table that belongs to the last row
            if (focusableElements.length > 0 && target === focusableElements[focusableElements.length - 1]) {
                e.preventDefault();
                onAdd();
                
                // Try to focus the first input of the newly added row
                setTimeout(() => {
                    if (!e.currentTarget) return;
                    const newInputs = Array.from(e.currentTarget.querySelectorAll('input:not([type="hidden"]), select, textarea, button'))
                        .filter(el => !(el as HTMLInputElement).disabled && (el as HTMLElement).tabIndex !== -1) as HTMLElement[];
                    if (newInputs.length > focusableElements.length) {
                        newInputs[focusableElements.length]?.focus();
                    }
                }, 50);
            }
        }
    };

    return (
        <div className="border border-slate-300 rounded-lg bg-white shadow-sm flex flex-col relative">
            {/* Column Toggler Popover (Odoo Style) */}
            {showSettings && (
                <div className="absolute left-0 top-10 z-50 bg-white border border-slate-200 shadow-xl rounded-sm py-2 min-w-[220px]">
                    <div className="px-3 py-1 text-xs font-bold text-slate-500 uppercase tracking-wider mb-1">
                        إظهار/إخفاء الأعمدة
                    </div>
                    <div className="max-h-60 overflow-y-auto">
                        {columns.filter(c => !c.required).map(col => (
                            <label key={col.id} className="flex flex-row-reverse justify-between items-center px-4 py-2 hover:bg-slate-50 cursor-pointer">
                                <span className="text-sm text-slate-700">{col.label}</span>
                                <input
                                    type="checkbox"
                                    checked={visibleColumns[col.id]}
                                    onChange={() => toggleColumn(col.id)}
                                    className="rounded border-slate-300 text-indigo-600 focus:ring-indigo-500 w-4 h-4"
                                />
                            </label>
                        ))}
                    </div>
                </div>
            )}

            <div className="overflow-x-auto">
                <table className="min-w-full divide-y divide-slate-200">
                    <thead className="bg-[#f8f9fa] text-slate-700">
                        <tr>


                            {activeColumns.map(col => (
                                <th
                                    key={col.id}
                                    className="p-0 text-right bg-[#f8f9fa] border-l border-slate-200 last:border-l-0"
                                >
                                    <div 
                                      className="px-2 py-1.5 text-xs font-bold text-slate-500 whitespace-nowrap overflow-hidden z-10 relative flex"
                                      style={{ width: col.width || 'auto', minWidth: col.minWidth || '60px', resize: 'horizontal', direction: 'rtl' }}
                                    >
                                        <span className="flex-1">{col.renderHeader ? col.renderHeader() : col.label}</span>
                                    </div>
                                </th>
                            ))}

                            {/* Actions Column */}
                            <th className="w-10 px-2 py-2"></th>

                            {/* Settings Icon */}
                            <th className="w-8 px-2 py-2 text-center align-middle">
                                <button
                                    type="button"
                                    className="text-slate-400 hover:text-slate-800 transition-colors"
                                    onClick={() => setShowSettings(!showSettings)}
                                >
                                    <SlidersHorizontal className="w-4 h-4" />
                                </button>
                            </th>
                        </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100 bg-white" onKeyDown={handleKeyDown}>
                        {fields.map((field: any, index) => {
                            const type = field.type || 'product';

                            if (type === 'section') {
                                return (
                                    <tr key={field.id} className="bg-slate-100 group">
                                        <td className="px-2 py-2 text-center cursor-move text-slate-400">
                                            <GripVertical className="w-4 h-4 mx-auto" />
                                        </td>
                                        <td colSpan={activeColumns.length} className="px-4 py-2">
                                            <input
                                                {...register(`lines.${index}.description`)}
                                                className="w-full bg-transparent font-bold text-slate-800 outline-none placeholder-slate-500"
                                                placeholder="عنوان القسم..."
                                                autoFocus
                                            />
                                            <input type="hidden" {...register(`lines.${index}.type`)} value="section" />
                                        </td>
                                        <td className="px-2 py-1 text-center">
                                            {!readOnly && (
                                                <button type="button" onClick={() => onRemove(index)} className="text-slate-400 hover:text-red-500 p-1">
                                                    <Trash2 className="w-4 h-4" />
                                                </button>
                                            )}
                                        </td>
                                        <td></td>
                                    </tr>
                                );
                            }

                            if (type === 'note') {
                                return (
                                    <tr key={field.id} className="bg-white group">
                                        <td className="px-2 py-2 text-center cursor-move text-slate-400">
                                            <GripVertical className="w-4 h-4 mx-auto" />
                                        </td>
                                        <td colSpan={activeColumns.length} className="px-4 py-2">
                                            <input
                                                {...register(`lines.${index}.description`)}
                                                className="w-full bg-transparent italic text-slate-600 outline-none placeholder-slate-400"
                                                placeholder="ملاحظة..."
                                                autoFocus
                                            />
                                            <input type="hidden" {...register(`lines.${index}.type`)} value="note" />
                                        </td>
                                        <td className="px-2 py-1 text-center">
                                            {!readOnly && (
                                                <button type="button" onClick={() => onRemove(index)} className="text-slate-400 hover:text-red-500 p-1">
                                                    <Trash2 className="w-4 h-4" />
                                                </button>
                                            )}
                                        </td>
                                        <td></td>
                                    </tr>
                                );
                            }

                            return (
                                <tr key={field.id} className={`group hover:bg-slate-50 relative ${activeRow === index ? 'bg-indigo-50/50' : ''}`} onClick={() => setActiveRow(index)}>
                                    <td className="px-1 py-1 relative text-center cursor-pointer" style={{ width: '28px' }}>
                                        {activeRow === index ? (
                                            <div className="absolute top-1/2 -translate-y-1/2 right-1 w-max text-indigo-600 animate-pulse flex items-center">
                                                <ArrowRight className="w-4 h-4 ml-0.5" />
                                            </div>
                                        ) : (
                                            <span className="text-xs text-slate-400">{index + 1}</span>
                                        )}
                                    </td>

                                    {activeColumns.map(col => (
                                        <td key={col.id} className="p-0 m-0 border-l border-slate-100 last:border-l-0 align-top focus-within:ring-2 focus-within:ring-[#714B67] focus-within:ring-inset relative">
                                            {col.renderCell(field, index, register, control)}
                                        </td>
                                    ))}

                                    <td className="px-2 py-1 text-center">
                                        {!readOnly && (
                                            <button
                                                type="button"
                                                onClick={() => onRemove(index)}
                                                className="text-slate-500 hover:text-red-600 transition-colors p-1.5 rounded hover:bg-slate-100"
                                                title="حذف"
                                            >
                                                <Trash2 className="w-4 h-4" />
                                            </button>
                                        )}
                                    </td>
                                    <td></td>
                                </tr>
                            );
                        })}

                        {/* Empty/Add Row State */}
                        {!disableAdd && !readOnly && (
                            <tr>
                                <td colSpan={activeColumns.length + 3} className="px-2 py-2">
                                    <div className="flex gap-4">
                                        <button
                                            type="button"
                                            onClick={onAdd}
                                            className="flex items-center gap-1 text-teal-700 hover:text-teal-900 text-sm font-medium px-2 py-1 rounded hover:bg-teal-50 transition-colors"
                                        >
                                            <Plus className="w-4 h-4" />
                                            إضافة منتج
                                        </button>
                                        <button
                                            type="button"
                                            onClick={onAddSection}
                                            className="flex items-center gap-1 text-teal-700 hover:text-teal-900 text-sm font-medium px-2 py-1 rounded hover:bg-teal-50 transition-colors"
                                        >
                                            <Plus className="w-4 h-4" />
                                            إضافة قسم
                                        </button>
                                        <button
                                            type="button"
                                            onClick={onAddNote}
                                            className="flex items-center gap-1 text-teal-700 hover:text-teal-900 text-sm font-medium px-2 py-1 rounded hover:bg-teal-50 transition-colors"
                                        >
                                            <Plus className="w-4 h-4" />
                                            إضافة ملاحظة
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        )}
                    </tbody>
                </table>
            </div>
        </div>
    );
}
