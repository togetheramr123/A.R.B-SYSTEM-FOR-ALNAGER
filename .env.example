# ==================================
# ERP 2026 — Environment Variables
# ==================================
# انسخ هذا الملف وسمه .env وعدل القيم

# --- قاعدة البيانات ---
# SQLite (للتطوير المحلي فقط)
DATABASE_URL="file:./dev.db"

# PostgreSQL (للإنتاج — Neon / Supabase / Railway)
# DATABASE_URL="postgresql://user:password@host:5432/erp_db?schema=public"

# --- مفتاح التشفير (JWT) ---
# ⛔ غيّر هذا لقيمة عشوائية قوية في الإنتاج!
# يمكنك توليد مفتاح بـ: openssl rand -base64 32
JWT_SECRET="change-me-to-a-strong-random-secret-key-in-production"

# --- مفتاح بوابة التجار (Portal JWT) ---
# مفتاح منفصل عن مفتاح ERP الرئيسي
PORTAL_JWT_SECRET="change-me-portal-secret-key"

# --- إعدادات Next.js ---
NODE_ENV="development"
# NODE_ENV="production"  # ← فعّل هذا في بيئة الإنتاج

# --- تسجيل دخول تلقائي (تطوير فقط) ---
# ⛔ لا تفعّل هذا أبداً في بيئة الإنتاج!
DEV_AUTO_LOGIN="true"
# DEV_AUTO_LOGIN="false"  # ← في الإنتاج

# --- إعدادات اختيارية ---
# NEXT_PUBLIC_APP_URL="https://your-domain.com"
