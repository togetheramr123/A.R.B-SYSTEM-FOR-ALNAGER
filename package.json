{
  "name": "smart-erp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/cron.js & next dev",
    "build": "next build",
    "start": "node scripts/cron.js & next start",
    "lint": "eslint",
    "check": "tsc --noEmit",
    "db:push": "npx prisma db push",
    "db:generate": "npx prisma generate",
    "db:seed": "npx prisma db seed",
    "deploy:prepare": "npm run check && npm run db:generate && npm run build",
    "verify:master": "ts-node -r tsconfig-paths/register --project tsconfig.script.json scripts/verify_master_cycle.ts",
    "test": "npx playwright test",
    "test:report": "npx playwright show-report",
    "backup": "node scripts/backup.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
