    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/types": "^7.29.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/decimal.js": "^0.0.32",
    "@types/minimatch": "^5.1.2",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xmlrpc": "^1.3.10",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
